   ],
   "source": [
    "n = int(input(\"Enter a number: \"))\n",
    "is_prime = True\n",
    "if n <= 1:\n",
    "    is_prime = False\n",
    "else:\n",
    "    for i in range(2, n):\n",
    "        if n % i == 0:\n",
    "            is_prime = False\n",
    "            break\n",
    "if is_prime:\n",
    "    print(\"Prime number.\")\n",
    "else:\n",
    "    print(\"NOT a prime number.\")"
   ]
  },
