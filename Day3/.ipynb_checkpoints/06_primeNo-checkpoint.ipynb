   "source": [
    "n=int(input(\"enter a number: \"))\n",
    "isprime=True\n",
    "if n<=1:\n",
    "    isprime=False\n",
    "else:\n",
    "    for i in range(2,n):\n",
    "        if n%i==0:\n",
    "            isprime=False\n",
    "            break\n",
    "if isprime:\n",
    "    print(\"Prime\")\n",
    "else:\n",
    "    print(\"not prime\")"
   ]
