   "source": [
    "<h5>Palindrome"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "6ea7efda-baed-42ba-a15b-87e128f34da7",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "enter a number:  45\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Not Palindrome\n"
     ]
    }
   ],
   "source": [
    "num=int(input(\"enter a number: \"))\n",
    "copy=num\n",
    "rev=0\n",
    "while copy>0:\n",
    "    d=copy%10;\n",
    "    rev=rev*10+d\n",
    "    copy=copy//10\n",
    "if num==rev:\n",
    "    print(\"Palindrome\")\n",
    "else:\n",
    "    print(\"Not Palindrome\")"
   ]
  },
